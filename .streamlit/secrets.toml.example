# =============================================================================
# secrets.toml.example — Estrutura das credenciais para o Streamlit Cloud
#
# INSTRUÇÕES:
#   1. Copie este arquivo para .streamlit/secrets.toml
#   2. Preencha cada campo com os valores reais
#   3. NUNCA commite o secrets.toml no repositório (já está no .gitignore)
#
# No Streamlit Cloud: cole o conteúdo em App Settings → Secrets
# =============================================================================

# Supabase (Project Settings → API). SERVICE_KEY ignora RLS — uso server-side.
[supabase]
url = "https://YOUR_PROJECT_REF.supabase.co"
service_key = "YOUR_SERVICE_ROLE_KEY"
# schema opcional (default: public)
schema = "public"

# -----------------------------------------------------------------------------
# Autenticação do dashboard
# -----------------------------------------------------------------------------
[auth_config]
cookie_name = "bling_dashboard_auth"
cookie_key = "YOUR_COOKIE_SECRET"
cookie_expiry_days = 7

[auth_config.credentials.usernames.admin]
name = "Admin"
password = "BCRYPT_HASH_AQUI"
role = "admin"
