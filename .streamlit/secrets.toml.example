# =============================================================================
# secrets.toml.example — Estrutura das credenciais para o Streamlit Cloud
#
# INSTRUÇÕES:
#   1. Copie este arquivo para .streamlit/secrets.toml
#   2. Preencha cada campo com os valores reais
#   3. NUNCA commite o secrets.toml no repositório (já está no .gitignore)
#
# No Streamlit Cloud: cole o conteúdo em App Settings → Secrets
# =============================================================================

# ID da planilha Google Sheets
# Encontre na URL: https://docs.google.com/spreadsheets/d/SHEET_ID/edit
sheet_id = "YOUR_SHEET_ID_HERE"

# Credenciais da Service Account (JSON completo gerado no Google Cloud Console)
[gcp_service_account]
type = "service_account"
project_id = "YOUR_PROJECT_ID"
private_key_id = "YOUR_PRIVATE_KEY_ID"
private_key = "-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT_HERE\n-----END RSA PRIVATE KEY-----\n"
client_email = "YOUR_SERVICE_ACCOUNT_NAME@YOUR_PROJECT_ID.iam.gserviceaccount.com"
client_id = "YOUR_CLIENT_ID"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/YOUR_SERVICE_ACCOUNT_NAME%40YOUR_PROJECT_ID.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
